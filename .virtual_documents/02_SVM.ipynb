#accuracy function
class accuracy(object):
    
    def __init__(self):
        pass
        
    def calculate(self, y_pred, y_true):
        self.y_pred = y_pred
        self.y_true = y_true
        #counts same labels, divides it by total size of array
        self.acc = np.count_nonzero((np.abs(y_pred-y_true))==0)/np.size(self.y_true)
        return float(self.acc)
    












