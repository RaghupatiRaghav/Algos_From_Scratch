b3_mod_train_x = normalize_data(b3_mod)[0]
b4_mod_train_x = normalize_data(b4_mod)[0]
b5_mod_train_x = normalize_data(b5_mod)[0]
test_mod_x = normalize_data(test_mod)[0]


